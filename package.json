{
  "name": "caro-multiplayer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts --host 0.0.0.0",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "rm -rf dist/server dist/shared && tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "npm run build && pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop caro-multiplayer",
    "pm2:delete": "pm2 delete caro-multiplayer",
    "pm2:logs": "pm2 logs caro-multiplayer",
    "pm2:save": "pm2 save",
    "lan:ip": "hostname -I"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "pm2": "^6.0.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "5.4.11",
    "vitest": "^2.1.8"
  }
}
